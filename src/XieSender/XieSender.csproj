<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net8.0-windows</TargetFramework>
        <LangVersion>12</LangVersion>
        <Nullable>enable</Nullable>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <OutputType>Library</OutputType>
        <Version>0.3.0</Version>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>

        <!-- NuGet Packaging -->
        <PackageId>AndanteTribe.XieSender</PackageId>
        <PackageVersion>$(Version)</PackageVersion>
        <Authors>Oryosan59, AndanteTribe</Authors>
        <Copyright>© Oryosan59, AndanteTribe</Copyright>
        <Description>Lightweight and optimized sender-only implementation extracted from XInputEdge.</Description>
        <PackageProjectUrl>https://github.com/AndanteTribe/XieSender</PackageProjectUrl>
        <RepositoryUrl>$(PackageProjectUrl)</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
    </PropertyGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="XieSender.Tests" />
    </ItemGroup>

</Project>
